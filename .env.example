BOT_TOKEN=
ETERNAL_API_KEY=
ETERNAL_API_URL=https://open.eternalai.org/v1/chat/completions
ETERNAL_MODEL=uncensored-eternal-ai-1.0
UPI_ID=
PORT=8000
ADMIN_USER_IDS=
TIMEZONE=Asia/Kolkata
RETENTION_ENABLED=false
PAYMENT_WALL_ENABLED=true
DATABASE_PATH=savita.db
CALLBACK_SECRET=
EXTERNAL_ACCESS_ENABLED=false

# External payments DB (xibots)
PAYMENTS_DB_HOST=
PAYMENTS_DB_PORT=3306
PAYMENTS_DB_USER=
PAYMENTS_DB_PASS=
PAYMENTS_DB_NAME=

# External subscriptions DB (xibots)
SUBS_DB_HOST=
SUBS_DB_PORT=3306
SUBS_DB_USER=
SUBS_DB_PASS=
SUBS_DB_NAME=

# Each query receives two params in order: (telegram_id, username)
PAYMENTS_DB_CHECK_QUERY=SELECT 1 FROM payments WHERE (telegram_id = %s OR username = %s) AND status IN ('success','paid','approved','completed') ORDER BY id DESC LIMIT 1
SUBS_DB_CHECK_QUERY=SELECT 1 FROM subscriptions WHERE (telegram_id = %s OR username = %s) AND status = 'active' AND (expires_at IS NULL OR expires_at > NOW()) ORDER BY id DESC LIMIT 1
